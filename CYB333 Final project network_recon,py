import socket

def scan_port(ip, port):
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(1)

    result = sock.connect_ex((ip, port))
    sock.close()

    if result == 0:
        print(f"Port {port} is OPEN")
    else:
        print(f"Port {port} is CLOSED")

ip = input("Enter IP Address: ")

ports = [21, 22, 80, 443]

for port in ports:
    scan_port(ip, port)
